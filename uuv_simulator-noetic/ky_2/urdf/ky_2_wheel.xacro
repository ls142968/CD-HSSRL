<?xml version="1.0"?>
<xacro:macro name="wheel_joint_with_friction" params="joint_name parent_link child_link xyz rpy effort velocity mu1 mu2">

 
  <joint name="${joint_name}" type="continuous">
    <parent link="${parent_link}" />
    <child link="${child_link}" />
    <origin xyz="${xyz}" rpy="${rpy}" />
    <axis xyz="0 1 0" />
    <limit effort="${effort}" velocity="${velocity}" />
    <dynamics damping="0.0" friction="0.0" />
    <hardwareInterface>${hardwareInterface}</hardwareInterface>
  </joint>


  <gazebo reference="${child_link}">
    <mu1>${mu1}</mu1>
    <mu2>${mu2}</mu2>
    <kp>1000000.0</kp>
    <kd>1.0</kd>
  </gazebo>

</xacro:macro>
