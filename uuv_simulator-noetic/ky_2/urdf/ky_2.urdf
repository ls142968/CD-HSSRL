<?xml version="1.0"?>
<robot
  name="ky_2">

   <!-- 添加 gazebo_ros_control 插件 -->
  <gazebo>
    <plugin name="gazebo_ros_control" filename="libgazebo_ros_control.so">
      <!-- 控制器的配置文件路径 -->
      <rosparam command="load" file="$(find ky_2)/config/controllers.yaml"/>
      <!-- 启动控制器管理器 -->
      <robotNamespace>/ky_2</robotNamespace>
    </plugin>
  </gazebo>

